{
  "version": 2,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    {
      "source": "/note/:id",
      "has": [{ "type": "query", "key": "raw", "value": "true" }],
      "destination": "/api/index.js"
    },
    {
      "source": "/note/:id",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(curl|Wget|Postman|insomnia|HTTPie|axios|node-fetch|got|undici).*"
        }
      ],
      "destination": "/api/index.js"
    },
    { "source": "/note/:id", "destination": "/api/index.js" },
    { "source": "/note/", "destination": "/index.html" },
    { "source": "/note", "destination": "/index.html" }
  ]
}
