{
  "version": 2,
  "rewrites": [
    { "source": "/api/note/:id", "destination": "/api/index.js" },
    { "source": "/api/create", "destination": "/api/index.js" },
    {
      "source": "/note/:id",
      "has": [{ "type": "query", "key": "raw", "value": "true" }],
      "destination": "/api/index.js"
    },
    { "source": "/note/:id", "destination": "/index.html" },
    { "source": "/note", "destination": "/index.html" }
  ]
}
